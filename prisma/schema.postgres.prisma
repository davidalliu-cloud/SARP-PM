generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  NOT_STARTED
  ACTIVE
  ON_HOLD
  FINISHED
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(EMPLOYEE)
  sessions     Session[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Session {
  id           String   @id @default(cuid())
  tokenHash    String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model Project {
  id           String        @id @default(cuid())
  name         String
  clientName   String?
  startDate    DateTime
  status       ProjectStatus @default(NOT_STARTED)
  dailyRecords DailyRecord[]
  invoices     Invoice[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Product {
  id                 String             @id @default(cuid())
  name               String
  unit               String
  defaultCostPerUnit Float
  usageItems         ProductUsageItem[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model Employee {
  id               String              @id @default(cuid())
  name             String
  role             String?
  defaultDailyWage Float
  labourItems      LabourEntryItem[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model ExpenseType {
  id            String        @id @default(cuid())
  name          String
  defaultAmount Float         @default(0)
  notes         String?
  expenseItems  ExpenseItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model DailyRecord {
  id           String             @id @default(cuid())
  projectId    String
  project      Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  date         DateTime
  notes        String?
  productItems ProductUsageItem[]
  labourItems  LabourEntryItem[]
  expenseItems ExpenseItem[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model ProductUsageItem {
  id            String      @id @default(cuid())
  dailyRecordId String
  dailyRecord   DailyRecord @relation(fields: [dailyRecordId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  quantity      Float
  costPerUnit   Float
}

model LabourEntryItem {
  id                 String      @id @default(cuid())
  dailyRecordId      String
  dailyRecord        DailyRecord @relation(fields: [dailyRecordId], references: [id], onDelete: Cascade)
  employeeId         String?
  employee           Employee?   @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  employeeName       String?
  externalTeamName   String?
  ratePerSquareMeter Float?
  squareMeters       Float?
  dailyWage          Float
}

model ExpenseItem {
  id            String       @id @default(cuid())
  dailyRecordId String
  dailyRecord   DailyRecord  @relation(fields: [dailyRecordId], references: [id], onDelete: Cascade)
  expenseTypeId String?
  expenseType   ExpenseType? @relation(fields: [expenseTypeId], references: [id])
  category      String
  description   String?
  amount        Float
}

model Invoice {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invoiceDate  DateTime
  monthCovered String
  invoiceNo    String?
  amount       Float
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
